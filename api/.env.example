# 安盾科技官网 API 配置

# 服务端口
PORT=3001

# SMTP 邮件配置（发送客户通知邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@andun.io

# 销售团队邮箱（接收新客户通知）
SALES_EMAIL=sales@andun.io

# OpenClaw Gateway 配置（Agent 通知）
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=ollama

# 管理后台地址
ADMIN_URL=http://localhost:3001/admin

# 数据库路径（可选，默认使用 api/data/contacts.db）
# DB_PATH=/path/to/contacts.db